<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml — Luki Play Android
    ─────────────────────────────────────────
    applicationId : com.luki.play
    minSdk        : 23  |  targetSdk : 35
    BASE_URL      : https://lukiplay.com  (debug y release)

    Arquitectura de Activities:
      SplashActivity  →  RouterActivity  →  TvMainActivity   (Android TV)
                                        →  MobileMainActivity (móvil/tablet)
      PlayerActivity  ←  invocada desde bridge JS

    TV App Quality Checklist:
      ✅ LEANBACK_LAUNCHER intent-filter (SplashActivity)
      ✅ android.hardware.touchscreen  required="false"
      ✅ android.software.leanback     required="false"
      ✅ android:banner definido (tv_banner.xml)
      ✅ android:roundIcon definido (mipmap-anydpi-v26)
      ✅ No touchscreen / telephony / GPS required
      ✅ FOREGROUND_SERVICE_MEDIA_PLAYBACK declarado
      ✅ hardwareAccelerated="true" a nivel de application
      ✅ networkSecurityConfig aplicado
      ✅ android:name=".LukiApplication" declarado
-->
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ════════════════════════════════════════════════════════
         PERMISOS
         ════════════════════════════════════════════════════════ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ════════════════════════════════════════════════════════
         HARDWARE FEATURES — TV APP QUALITY CHECKLIST
         Todas required="false" → elegible en Android TV / Google TV
         sin pantalla táctil, cámara, GPS ni telefonía.
         ════════════════════════════════════════════════════════ -->

    <!-- ✅ TV Quality OBLIGATORIO: touchscreen NOT required -->
    <uses-feature android:name="android.hardware.touchscreen"                    android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen.multitouch"         android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen.multitouch.distinct" android:required="false" />

    <!-- Leanback soportado pero no obligatorio (permite instalar en móvil también) -->
    <uses-feature android:name="android.software.leanback"  android:required="false" />

    <!-- ✅ CRÍTICO para Android TV: varias Activities declaran screenOrientation
         portrait/landscape, lo que hace que Android IMPLIQUE
         android.hardware.screen.portrait como requerida. Las TV no tienen
         pantalla portrait → Google las filtra como incompatibles.
         Declararlas required="false" explícitamente desactiva ese filtro. -->
    <uses-feature android:name="android.hardware.screen.portrait"  android:required="false" />
    <uses-feature android:name="android.hardware.screen.landscape" android:required="false" />

    <!-- Sensores y hardware opcionales -->
    <uses-feature android:name="android.hardware.camera"           android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.microphone"       android:required="false" />
    <uses-feature android:name="android.hardware.location"         android:required="false" />
    <uses-feature android:name="android.hardware.location.gps"     android:required="false" />
    <uses-feature android:name="android.hardware.telephony"        android:required="false" />

    <!-- ════════════════════════════════════════════════════════
         APLICACIÓN
         ════════════════════════════════════════════════════════ -->
    <queries>
        <!-- Necesario para que el Cast Framework descubra el MediaRouter. -->
        <intent>
            <action android:name="android.media.browse.MediaBrowserService" />
        </intent>
    </queries>

    <application
        android:name=".LukiApplication"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:banner="@drawable/banner_tv"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.LukiPlay.Splash"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <!-- Cast Framework auto-discovery -->
        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="com.luki.play.cast.LukiCastOptionsProvider" />

        <!-- ──────────────────────────────────────────────────────
             SplashActivity — Punto de entrada único
             ──────────────────────────────────────────────────────
             Muestra el splash y arranca RouterActivity.
             noHistory=true: no queda en el back-stack.
        -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:screenOrientation="nosensor"
            android:theme="@style/Theme.LukiPlay.Starting"
            android:noHistory="true">

            <!-- Lanzador estándar (móvil / tablet) -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- ✅ TV Quality OBLIGATORIO: LEANBACK_LAUNCHER -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ──────────────────────────────────────────────────────
             RouterActivity — Detecta TV vs móvil y redirige
             ──────────────────────────────────────────────────────
             No tiene layout propio; es invisible para el usuario.
        -->
        <activity
            android:name=".ui.RouterActivity"
            android:exported="false"
            android:screenOrientation="nosensor"
            android:theme="@style/Theme.LukiPlay.Splash"
            android:noHistory="true" />

        <!-- ──────────────────────────────────────────────────────
             TvMainActivity — WebView para Android TV / Google TV
             ──────────────────────────────────────────────────────
             Inyecta D-Pad JS helper; modo fullscreen/leanback.
        -->
        <activity
            android:name=".tv.TvMainActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.LukiPlay"
            android:windowSoftInputMode="adjustNothing"
            android:hardwareAccelerated="true" />

        <!-- TvComposeActivity — Android TV nativo en Compose for TV (Fase 4) -->
        <activity
            android:name=".tv.TvComposeActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.LukiPlay"
            android:windowSoftInputMode="adjustNothing"
            android:hardwareAccelerated="true" />

        <!-- ──────────────────────────────────────────────────────
             MobileMainActivity — WebView para móvil / tablet
             ──────────────────────────────────────────────────────
             Gestión de doble-back, toast de salida.
             screenOrientation=fullSensor: permite rotar a horizontal para que
             el reproductor web (HlsVideoPlayer) entre en pantalla completa al
             girar el teléfono, como YouTube. El fullscreen del <video> lo
             gestiona onShowCustomView en el WebChromeClient. configChanges
             incluye orientation|screenSize → la rotación NO recrea la Activity
             (el WebView no se recarga).
        -->
        <activity
            android:name=".mobile.MobileMainActivity"
            android:exported="false"
            android:screenOrientation="fullSensor"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.LukiPlay"
            android:windowSoftInputMode="adjustResize"
            android:hardwareAccelerated="true" />

        <!-- ──────────────────────────────────────────────────────
             MobileComposeActivity — móvil nativo en Compose (Fase 3)
             ──────────────────────────────────────────────────────
             Detrás de BuildConfig.NATIVE_HOME_ENABLED. RouterActivity
             decide entre ésta y MobileMainActivity en función del flag.
        -->
        <activity
            android:name=".mobile.MobileComposeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.LukiPlay"
            android:windowSoftInputMode="adjustResize"
            android:hardwareAccelerated="true" />

        <!-- ──────────────────────────────────────────────────────
             MainActivity — Actividad legacy / fallback WebView
             ──────────────────────────────────────────────────────
             Mantenida para compatibilidad con referencias existentes.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.LukiPlay"
            android:windowSoftInputMode="adjustResize"
            android:hardwareAccelerated="true" />

        <!-- ──────────────────────────────────────────────────────
             PlayerActivity — ExoPlayer / Media3 HLS fullscreen
             ──────────────────────────────────────────────────────
             launchMode=singleTop evita doble instancia al rotar.
             keepScreenOn gestionado por el tema Player.
        -->
        <!-- ──────────────────────────────────────────────────────
             LukiDownloadService — descargas offline (Media3) (Fase 5)
             ────────────────────────────────────────────────────── -->
        <service
            android:name=".data.downloads.LukiDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Desactivar auto-init de WorkManager para que se use el
             Configuration.Provider con HiltWorkerFactory en LukiApplication. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <activity
            android:name=".player.PlayerActivity"
            android:exported="false"
            android:screenOrientation="sensorLandscape"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize"
            android:theme="@style/Theme.LukiPlay.Player"
            android:launchMode="singleTop"
            android:supportsPictureInPicture="true"
            android:resizeableActivity="true"
            android:hardwareAccelerated="true" />

    </application>

</manifest>
