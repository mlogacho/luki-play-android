<?xml version="1.0" encoding="utf-8"?>
<!--
    network_security_config.xml — Luki Play Android (RELEASE)
    ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Política de PRODUCCIÓN: cleartext HTTP PROHIBIDO para todo.
    Toda la comunicación (backend, portal web, API) va por HTTPS.

    Las excepciones de desarrollo/QA (servidor 98.80.97.51 y test-streams.mux.dev
    por HTTP) se declaran ÚNICAMENTE en el override de debug
    (src/debug/res/xml/network_security_config.xml), de modo que NO llegan al
    AAB que se sube a Google Play.
-->
<network-security-config>

    <!-- Política global: cleartext PROHIBIDO. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Producción: lukiplay.com — solo HTTPS, sin excepción -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">lukiplay.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

</network-security-config>
