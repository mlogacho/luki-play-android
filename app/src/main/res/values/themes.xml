<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ══════════════════════════════════════════════════════
         BASE — Sin ActionBar, DayNight habilitado
         ══════════════════════════════════════════════════════ -->
    <style name="Base.Theme.LukiPlay" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Colores de marca -->
        <item name="colorPrimary">@color/luki_navy</item>
        <item name="colorPrimaryDark">@color/luki_dark</item>
        <item name="colorAccent">@color/luki_cyan</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/luki_dark</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- Texto — Mejorado para accesibilidad -->
        <item name="android:textColorPrimary">@color/luki_text_primary</item>
        <item name="android:textColorSecondary">@color/luki_text_secondary</item>
        <item name="android:textSize">@dimen/text_body</item>
    </style>

    <!-- ══════════════════════════════════════════════════════
         TEMA PRINCIPAL — WebView / MainActivity
         ══════════════════════════════════════════════════════ -->
    <style name="Theme.LukiPlay" parent="Base.Theme.LukiPlay">
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/luki_dark</item>
        <item name="android:navigationBarColor">@color/luki_dark</item>
    </style>

    <!-- ══════════════════════════════════════════════════════
         TEMA PLAYER — ExoPlayer fullscreen
         Reemplaza Theme.LukiPlay.Fullscreen con nombre canónico
         referenciado en AndroidManifest.xml
         ══════════════════════════════════════════════════════ -->
    <style name="Theme.LukiPlay.Player" parent="Theme.LukiPlay">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:keepScreenOn">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Alias para compatibilidad con código existente -->
    <style name="Theme.LukiPlay.Fullscreen" parent="Theme.LukiPlay.Player" />

    <!-- ══════════════════════════════════════════════════════
         TEMA ARRANQUE — SplashScreen API (Android 12+)
         Elimina la pantalla blanca del sistema al abrir la app.
         ══════════════════════════════════════════════════════ -->
    <style name="Theme.LukiPlay.Starting" parent="Theme.SplashScreen">
        <!-- Mismo violeta que arranca el degradado del login nativo, para que
             splash → router → login sea un solo color y no tres. -->
        <item name="windowSplashScreenBackground">@color/luki_purple</item>
        <!-- El PNG lleva margen transparente a propósito: Android 12+ enmascara
             el icono en círculo y el logo a sangre perdería el badge "play".
             Es bitmap, no vector: un VectorDrawable sin <path> fue justo lo que
             crasheaba en Android ≤ 11, donde la librería lo infla a mano. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.LukiPlay</item>
    </style>

    <!-- ══════════════════════════════════════════════════════
         TEMA SPLASH — Pantalla de inicio
         ══════════════════════════════════════════════════════ -->
    <!-- Lo usan RouterActivity (invisible, solo redirige) y la <application>.
         Comparte color con Theme.LukiPlay.Starting: antes era azul marino y
         el arranque saltaba de casi-negro a marino y luego al violeta del
         login. -->
    <style name="Theme.LukiPlay.Splash" parent="Base.Theme.LukiPlay">
        <item name="android:windowBackground">@color/luki_purple</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@color/luki_purple</item>
        <item name="android:navigationBarColor">@color/luki_purple</item>
    </style>

    <!-- ══════════════════════════════════════════════════════
         ESTILOS DE COMPONENTES — Reutilizables
         ══════════════════════════════════════════════════════ -->

    <!-- Botón primario mejorado -->
    <style name="Button.Primary" parent="Widget.AppCompat.Button">
        <item name="android:minHeight">@dimen/button_height_primary</item>
        <item name="android:minWidth">@dimen/button_height_primary</item>
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textStyle">bold</item>
        <item name="android:backgroundTint">@color/luki_focus</item>
    </style>

    <!-- Base style required by dot-notation children (Text.H1, Text.H2, etc.) -->
    <style name="Text" parent="android:style/TextAppearance">
        <item name="android:textColor">@color/luki_text_primary</item>
    </style>

    <!-- Texto de encabezado H1 -->
    <style name="Text.H1">
        <item name="android:textSize">@dimen/text_h1</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/luki_text_primary</item>
    </style>

    <!-- Texto de encabezado H2 -->
    <style name="Text.H2">
        <item name="android:textSize">@dimen/text_h2</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/luki_text_primary</item>
    </style>

    <!-- Texto de encabezado H3 -->
    <style name="Text.H3">
        <item name="android:textSize">@dimen/text_h3</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/luki_text_primary</item>
    </style>

    <!-- Texto de cuerpo principal -->
    <style name="Text.Body">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/luki_text_primary</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <!-- Texto de caption -->
    <style name="Text.Caption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/luki_text_secondary</item>
    </style>

</resources>
