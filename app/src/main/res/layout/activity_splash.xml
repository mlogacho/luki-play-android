<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_splash.xml — Pantalla de inicio Luki Play
    ───────────────────────────────────────────────────
    • Fondo navy oscuro con el logo centrado.
    • ProgressBar debajo del logo.
    • Sin dependencias de touch — navegable en TV.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/luki_navy"
    tools:context=".ui.SplashActivity">

    <!-- Logo centrado verticalmente (ligeramente hacia arriba del centro) -->
    <ImageView
        android:id="@+id/imageViewLogo"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/splash_logo"
        android:contentDescription="@string/cd_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/loadingBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.45" />

    <!-- Barra de progreso indeterminada debajo del logo -->
    <ProgressBar
        android:id="@+id/loadingBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="120dp"
        android:layout_height="4dp"
        android:layout_marginTop="24dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/luki_cyan"
        android:progressTint="@color/luki_cyan"
        android:contentDescription="@string/cd_loading"
        app:layout_constraintTop_toBottomOf="@+id/imageViewLogo"
        app:layout_constraintBottom_toTopOf="@+id/textLoading"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Texto "Cargando…" -->
    <TextView
        android:id="@+id/textLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/loading"
        android:textColor="#80FFFFFF"
        android:textSize="13sp"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toBottomOf="@+id/loadingBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
