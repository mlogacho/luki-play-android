<?xml version="1.0" encoding="utf-8"?>
<!--
    Custom live-TV controller layout for PlayerView.
    No seekbar, no rewind/forward, no time labels, no settings gear.
    Only shows: play/pause button (center) + EN VIVO badge (top-right).
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000">

    <!-- EN VIVO badge — top right corner -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="20dp"
        android:text="● EN VIVO"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:background="#CCE53935"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp" />

    <!-- Play / Pause — centered, uses Media3's built-in ID -->
    <ImageButton
        android:id="@id/exo_play_pause"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center"
        android:background="#CC000000"
        android:padding="14dp"
        android:contentDescription="@string/exo_controls_play_description" />

</FrameLayout>
