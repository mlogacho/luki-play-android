<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Luki Play Android  (TV-aware)
    ─────────────────────────────────────────────────
    • WebView ocupa todo el espacio disponible.
    • Offline banner deslizable desde abajo (gone por defecto).
    • ProgressBar de carga inicial (gone cuando la página carga).
    • No depende de touch: todos los elementos son focusables con D-Pad.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/luki_dark"
    tools:context=".MainActivity">

    <!-- ── WebView principal ─────────────────────────────────── -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Loading indicator centrado (visible durante la carga inicial) ── -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        style="?android:attr/progressBarStyle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/luki_cyan"
        android:visibility="visible"
        android:contentDescription="@string/cd_loading"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── Offline banner — aparece cuando no hay red ───────── -->
    <LinearLayout
        android:id="@+id/offlineBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC001E41"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        tools:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/offlineMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/error_no_internet"
            android:textColor="@color/luki_text_primary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/retry"
            android:backgroundTint="@color/luki_cyan"
            android:textColor="@color/luki_dark"
            android:textStyle="bold"
            android:focusable="true"
            android:layout_marginStart="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
