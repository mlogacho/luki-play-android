<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_foreground.xml — Capa de primer plano del ícono adaptativo
    Dimensiones: 108 × 108 dp  (zona segura: 72 × 72 dp en el centro)

    Logo: círculo cyan + letra "L" en navy + triángulo play en blanco
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Círculo de fondo cyan (zona segura 72dp centrada → radio 36, centro 54,54) -->
    <path
        android:fillColor="#00D4EA"
        android:pathData="M54,18 a36,36 0 1,0 0,72 a36,36 0 1,0 0,-72 z" />

    <!-- Triángulo "play" blanco centrado -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M46,40 L68,54 L46,68 Z" />

</vector>
